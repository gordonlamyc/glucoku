# Azure OpenAI Configuration
# Get this from: Azure Portal > Cognitive Services > Keys and Endpoint
VITE_AZURE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
VITE_AZURE_API_KEY=your_azure_api_key_here

# Blynk Configuration
# Get this from: Blynk Console > Device > Auth Token
VITE_BLYNK_AUTH_TOKEN=your_blynk_auth_token_here
VITE_BLYNK_API_URL=https://blynk.cloud/external/api/get
